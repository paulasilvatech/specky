# ============================================================
# Specky .gitignore — APM Package
# ============================================================
# TRACKED: apm.yml, apm.lock.yaml, apm-policy.yml, .apm/, src/, package.json, config.yml,
#          media/, README, LICENSE, CHANGELOG, SECURITY,
#          CONTRIBUTING, GETTING-STARTED, .github/workflows,
#          .github/ISSUE_TEMPLATE, .github/dependabot.yml,
#          index.html (site), templates/, tests/, docs/
# ============================================================

# ── Generated output ──────────────────────────────────────
node_modules/
dist/
coverage/
*.tgz
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Package-manager caches ───────────────────────────────
.npm/
.yarn/
.pnpm-store/

# ── Tooling caches ───────────────────────────────────────
*.tsbuildinfo
.vite/
.vitest/
.eslintcache
.turbo/
.nyc_output/
__pycache__/
*.py[cod]

# ── Test reports and generated previews ──────────────────
test-results/
playwright-report/
blob-report/
specky-*-mobile-*.png
*-preview.png

# ── Temporary files ──────────────────────────────────────
tmp/
temp/
.cache/
*.tmp
*.temp
*.swp
*.swo

# ── Environment & secrets ─────────────────────────────────
.env
.env.*

# ── OS artifacts ──────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE & editor config ──────────────────────────────────
.vscode/
.idea/

# ── AI tooling internals ─────────────────────────────────
.claude/
.cursor/
.agents/
.remember/
CLAUDE.md
BUILD_PROMPT.md
SESSION_LOG_*.md
.mcp.json

# ── APM consumer artifacts (not package content) ─────────
apm_modules/

# ── SDD process artifacts (per-project, not repo) ────────
.specs/
.specky/

# ── Local workspace assets / sibling checkouts ───────────
/harness/
images/
specky-site/

# ── Build config (internal) ──────────────────────────────
# NOTE: scripts/, .apm/hooks/scripts/, and .npmignore are tracked —
# they control packaging and ship-time behavior.
# Dockerfile + .dockerignore are tracked release artifacts (the GHCR image
# published by publish.yml and asserted by docs-enterprise.test.ts).
# docker-compose.yml stays ignored: it is generated per user-project by
# sdd_generate_dockerfile, never a repo artifact.
docker-compose.yml
ONBOARDING.md

# ─── Specky (vendored — regenerated by `specky install`) ───
# See https://github.com/paulasilvatech/specky/blob/main/docs/INSTALL.md#git
.github/*
!.github/ISSUE_TEMPLATE/
!.github/ISSUE_TEMPLATE/**
!.github/workflows/
!.github/workflows/**
!.github/dependabot.yml
.claude/agents/
.claude/commands/
.claude/skills/
.claude/hooks/
.claude/rules/
.specky/install.lock
.specky/install.json

# KEEP in git (project-specific — do NOT add these):
#   .specky/config.yml       pipeline config
#   .specky/profile.json     onboarding answers
#   .specs/                  your pipeline artifacts
#   .claude/settings.json    team-shared permissions + hooks
#   .mcp.json                MCP server registration
#   .vscode/mcp.json         MCP server registration (Copilot)
#   .vscode/settings.json    team-shared VS Code settings
# ─── end Specky ───
