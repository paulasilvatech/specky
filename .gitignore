# ============================================================
# Specky .gitignore — PUBLIC repo policy
# Keep: src/, package.json, media/, README, LICENSE, CHANGELOG,
#       SECURITY, CONTRIBUTING, GETTING-STARTED, .github/workflows
# Everything else is internal / generated
# ============================================================

# ── Generated output ──────────────────────────────────────
node_modules/
dist/
coverage/
*.tgz
*.log

# ── Environment & secrets ─────────────────────────────────
.env
.env.*

# ── OS artifacts ──────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE & editor config ──────────────────────────────────
.vscode/
.idea/

# ── AI tooling (Claude Code / Copilot internal) ──────────
.claude/
.remember/
CLAUDE.md
BUILD_PROMPT.md
SESSION_LOG_*.md
Specky_v3.2.0_Master_Prompt_v2_npm_default_*.md

# ── Copilot agents, skills, prompts (internal authoring) ─
.github/agents/
.github/skills/
.github/prompts/
.github/copilot-instructions.md

# ── SDD process artifacts (per-project, not repo content) ─
.specs/
.specky/
SDD/
ARCHITECTURE.md

# ── APM internals ───────────────────────────────────
.apm/
apm_modules/
apm.lock.yaml

# ── Build, test, packaging config (internal) ─────────────
templates/
tests/
scripts/
site/
docs/
vitest.config.ts
tsconfig.json
Dockerfile
docker-compose.yml
.dockerignore
.npmignore
PUBLISH.md
ONBOARDING.md

# ── Internal brand & reports ──────────────────────────────
brand/
reports/
svg-paulasilvatech/
