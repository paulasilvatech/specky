{
  "name": "specky-sdd",
  "version": "3.11.1",
  "description": "Specky — Spec-Driven Development CLI toolkit. 58 MCP tools, 13 agents, 22 prompts, 14 skills, 16 hooks. Unified `specky` CLI installs to Claude Code, GitHub Copilot, Cursor, or OpenCode on macOS, Linux, and Windows.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "specky": "dist/cli/index.js",
    "specky-sdd": "dist/cli/index.js"
  },
  "scripts": {
    "audit": "node scripts/check-manifest-sync.mjs && node scripts/audit-agent-frontmatter.mjs",
    "build": "node scripts/check-manifest-sync.mjs && node scripts/audit-agent-frontmatter.mjs && rm -rf dist && tsc && cp -r templates dist/templates && node scripts/build-hook-manifests.mjs && node scripts/finalize-build.mjs",
    "start": "node dist/cli/index.js serve",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/release.mjs"
  },
  "icon": "site/specky-icon.png",
  "files": [
    "dist/",
    ".apm/",
    "templates/",
    "apm.yml",
    "apm.lock.yaml",
    "apm-policy.yml",
    "config.yml",
    "site/specky-icon.png",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "spec-driven-development",
    "sdd",
    "ears-notation",
    "requirements",
    "specification",
    "copilot",
    "claude",
    "ai-agent"
  ],
  "author": "Paula Silva <paulasilvatech@github.com> (https://github.com/paulasilvatech)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulasilvatech/specky.git"
  },
  "homepage": "https://github.com/paulasilvatech/specky#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "types": "./dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/paulasilvatech/specky/issues"
  }
}